<Window x:Class="JacketCatalogCollector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DDR GP Jacket Catalog Collector (Developer)" Height="820" Width="1320"
        MinHeight="640" MinWidth="1000">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="masterを更新" Margin="0,0,8,0" Padding="14,8" Click="UpdateMaster_Click" />
                <Button Content="v1→v2移行" Margin="0,0,8,0" Padding="14,8" Click="MigrateCatalog_Click" />
                <Button Content="master/catalogを選択" Margin="0,0,8,0" Padding="14,8" Click="SelectDatabases_Click" />
                <Button Content="処理を取消" Padding="14,8" Click="CancelOperation_Click" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Jacket Catalog Collector" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Developer-only / audited manual jacket review" Foreground="DimGray" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Padding="12" Background="#EEF3F8" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="master" FontWeight="Bold" />
                    <TextBlock Text="{Binding MasterVersion}" />
                    <TextBlock Text="{Binding MasterSourceHash}" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="{Binding MasterCounts}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="catalog" FontWeight="Bold" />
                    <TextBlock><Run Text="{Binding CatalogIdentity, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding CatalogSchema, Mode=OneWay}" /></TextBlock>
                    <TextBlock><Run Text="capability: " /><Run Text="{Binding MutationCapability, Mode=OneWay}" /></TextBlock>
                    <TextBlock Text="{Binding CoverageSummary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding OrphanSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <TextBlock Text="status" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Width="150" ItemsSource="{Binding CoverageStatusOptions}"
                          SelectedItem="{Binding SelectedCoverageStatus}" Margin="0,0,12,0" />
                <TextBlock Text="reason" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Width="240" ItemsSource="{Binding ReasonOptions}"
                          SelectedItem="{Binding SelectedReason}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding StatusTitle}" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="DimGray" TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="3">
            <TabItem Header="Coverage songs">
                <DataGrid ItemsSource="{Binding Songs}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="status" Binding="{Binding CoverageStatus}" Width="120" />
                        <DataGridTextColumn Header="song" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="artist" Binding="{Binding Artist}" Width="*" />
                        <DataGridTextColumn Header="refs" Binding="{Binding ReferenceCount}" Width="60" />
                        <DataGridTextColumn Header="reason" Binding="{Binding Reason}" Width="2*" />
                        <DataGridTextColumn Header="song_id" Binding="{Binding SongId}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Review queue">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="song検索" />
                            <TextBox Text="{Binding SongSearch, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="明示選択song" />
                            <ComboBox ItemsSource="{Binding SongChoices}" SelectedItem="{Binding SelectedSong}"
                                      DisplayMemberPath="Title" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="reason / note（opaque）" />
                            <DockPanel>
                                <TextBox Width="120" Text="{Binding ReviewReason, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Margin="6,0,0,0" Text="{Binding ReviewNote, UpdateSourceTrigger=PropertyChanged}" />
                            </DockPanel>
                        </StackPanel>
                        <WrapPanel Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                            <Button Content="confirm" Tag="manual_confirm" Margin="4" Padding="10,5" Click="ReviewAction_Click" />
                            <Button Content="reassign" Tag="reassign" Margin="4" Padding="10,5" Click="ReviewAction_Click" />
                            <Button Content="reject" Tag="reject" Margin="4" Padding="10,5" Click="ReviewAction_Click" />
                            <Button Content="reopen" Tag="reopen" Margin="4" Padding="10,5" Click="ReviewAction_Click" />
                        </WrapPanel>
                    </Grid>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ReviewReferences}"
                              SelectedItem="{Binding SelectedReference}" IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="status" Binding="{Binding ReviewStatus}" Width="110" />
                            <DataGridTextColumn Header="rev" Binding="{Binding Revision}" Width="45" />
                            <DataGridTextColumn Header="observed title" Binding="{Binding ObservedTitle}" Width="*" />
                            <DataGridTextColumn Header="observed artist" Binding="{Binding ObservedArtist}" Width="*" />
                            <DataGridTextColumn Header="reason" Binding="{Binding Reason}" Width="*" />
                            <DataGridCheckBoxColumn Header="drift" Binding="{Binding MasterDrift}" Width="60" />
                            <DataGridTextColumn Header="candidates" Binding="{Binding CandidateDisplay}" Width="2*" />
                            <DataGridTextColumn Header="history" Binding="{Binding HistoryDisplay}" Width="2*" />
                            <DataGridTextColumn Header="reference_id" Binding="{Binding ReferenceId}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Window capture (memory only)">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="候補を更新" Margin="4" Padding="12,6" Click="RefreshWindows_Click" />
                            <Button Content="明示開始" Margin="4" Padding="12,6" Click="StartCapture_Click" />
                            <Button Content="停止" Margin="4" Padding="12,6" Click="StopCapture_Click" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="DDR GRAND PRIX window候補" FontWeight="Bold" />
                            <TextBlock Text="{Binding WindowCapture.CandidateStatus}" Foreground="DimGray" TextWrapping="Wrap" />
                        </StackPanel>
                    </DockPanel>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <DataGrid ItemsSource="{Binding WindowCapture.Candidates}"
                                  SelectedItem="{Binding WindowCapture.SelectedCandidate}"
                                  IsReadOnly="True" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="process / handle / title" Binding="{Binding DisplayName}" Width="2*" />
                                <DataGridTextColumn Header="candidate reason" Binding="{Binding CandidateReason}" Width="*" />
                                <DataGridCheckBoxColumn Header="visible" Binding="{Binding Identity.IsVisible}" Width="65" />
                                <DataGridCheckBoxColumn Header="min" Binding="{Binding Identity.IsMinimized}" Width="45" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="1" Margin="10,0,0,0" BorderBrush="#8899AA" BorderThickness="1" Background="#111820">
                            <Image Source="{Binding WindowCapture.Preview}" Stretch="Uniform" />
                        </Border>
                    </Grid>
                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <Border Padding="10" Background="#EEF3F8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding WindowCapture.SelectedIdentity}" FontFamily="Consolas" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding WindowCapture.SelectedReason}" Foreground="DimGray" />
                                    <TextBlock Text="{Binding WindowCapture.Lifecycle.Message}" TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding WindowCapture.CaptureState}" />
                                    <TextBlock Text="{Binding WindowCapture.CaptureCounts}" />
                                    <TextBlock Text="{Binding WindowCapture.CaptureSizes}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Margin="0,8,0,0" Padding="10" Background="#FFF7E6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Observation.StatusTitle}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Observation.StatusMessage}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Observation.StableCandidate}" FontFamily="Consolas" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock><Run Text="session: " /><Run Text="{Binding Observation.SessionId, Mode=OneWay}" /></TextBlock>
                                    <TextBlock Text="{Binding Observation.DetectorState}" />
                                    <TextBlock Text="{Binding Observation.DetectorProgress}" />
                                    <TextBlock><Run Text="catalog: " /><Run Text="{Binding Observation.LastCatalogReceipt, Mode=OneWay}" /></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBox Width="220" Margin="4" Padding="6"
                                             ToolTip="compatible checkpointのsession ID"
                                             Text="{Binding Observation.ResumeSessionId, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="session再開" IsEnabled="{Binding Observation.CanResume}" Margin="4" Padding="12,6" Click="ResumeCapture_Click" />
                                    <Button Content="候補を採用" IsEnabled="{Binding Observation.CanAdopt}" Margin="4" Padding="12,6" Click="AdoptObservation_Click" />
                                    <Button Content="catalog retry (pending/deferred)" Margin="4" Padding="12,6" Click="RetryCatalog_Click" />
                                    <Button Content="title/artist評価" Margin="4" Padding="12,6" Click="EvaluateTitleArtist_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
