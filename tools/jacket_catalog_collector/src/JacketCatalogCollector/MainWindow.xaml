<Window x:Class="JacketCatalogCollector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JacketCatalogCollector"
        Title="DDR GP ジャケット収集" Height="860" Width="1320"
        MinHeight="700" MinWidth="1040" Background="#F3F4F6"
        Loaded="MainWindow_Loaded">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1565C0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="52" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D8DEE8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB" />
            <Setter Property="Foreground" Value="#6B7280" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
        <local:ManualReviewRoiImageConverter x:Key="ManualReviewRoiImageConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Border Padding="12,7" Background="#F0FDF4" BorderBrush="#BBF7D0"
                        BorderThickness="1" CornerRadius="16" Margin="0,0,8,0">
                    <TextBlock Foreground="#166534">
                        <Run Text="曲情報: " /><Run Text="{Binding MasterVersion, Mode=OneWay}" />
                    </TextBlock>
                </Border>
                <Border Padding="12,7" Background="#EFF6FF" BorderBrush="#BFDBFE"
                        BorderThickness="1" CornerRadius="16">
                    <TextBlock Foreground="#1E40AF">
                        <Run Text="ジャケット情報: " /><Run Text="{Binding CatalogSchema, Mode=OneWay}" />
                    </TextBlock>
                </Border>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="DDR GP ジャケット収集" FontSize="20" FontWeight="SemiBold" />
                <TextBlock Text="曲を切り替えながら、検出したジャケットを確認して保存します。"
                           Foreground="#6B7280" FontSize="12" Margin="0,3,0,0" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1" Background="White">
            <TabItem Header="ジャケット収集">
                <Grid Margin="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Grid Margin="0,0,14,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="190" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right" Content="ウィンドウを再検索"
                                    Click="RefreshWindows_Click" />
                            <StackPanel>
                                <TextBlock Text="DDR GPの画面" FontSize="17" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding WindowCapture.CandidateStatus}"
                                           Foreground="#5F6B7A" TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1" BorderBrush="#293340" BorderThickness="1"
                                Background="#111820" CornerRadius="6">
                            <Image Source="{Binding WindowCapture.Preview}" Stretch="Uniform" />
                        </Border>

                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="使用するDDR GPウィンドウを選択" FontWeight="SemiBold" />
                            <DataGrid Grid.Row="1" Margin="0,6,0,0"
                                      ItemsSource="{Binding WindowCapture.Candidates}"
                                      SelectedItem="{Binding WindowCapture.SelectedCandidate}"
                                      IsReadOnly="True" AutoGenerateColumns="False"
                                      HeadersVisibility="Column" SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="ウィンドウ" Binding="{Binding DisplayName}" Width="2*" />
                                    <DataGridTextColumn Header="検出理由" Binding="{Binding CandidateReason}" Width="*" />
                                    <DataGridCheckBoxColumn Header="表示中" Binding="{Binding Identity.IsVisible}" Width="65" />
                                    <DataGridCheckBoxColumn Header="最小化" Binding="{Binding Identity.IsMinimized}" Width="65" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>

                    <StackPanel Grid.Column="1">
                        <Border Style="{StaticResource Card}" Background="#EEF6FF">
                            <StackPanel>
                                <TextBlock Text="{Binding Observation.CollectionStateTitle}"
                                           FontSize="21" FontWeight="SemiBold" TextWrapping="Wrap" />
                                 <TextBlock Text="{Binding Observation.CollectionStateMessage}"
                                            Margin="0,8,0,14" Foreground="#44505F" FontSize="14"
                                            TextWrapping="Wrap" />
                                <CheckBox Content="このsessionで保存前照合済み候補を自動保存する（既定OFF）"
                                          IsChecked="{Binding Observation.AutoSaveEnabled, Mode=TwoWay}"
                                          IsEnabled="{Binding Observation.CanConfigureAutoSave}"
                                          Margin="0,0,0,10" />
                                <Button Content="このジャケットを保存"
                                        Style="{StaticResource PrimaryButton}"
                                        IsEnabled="{Binding Observation.CanAdopt}"
                                        Click="AdoptObservation_Click" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="1. DDR GPへ接続" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="左の一覧から表示中のDDR GPを選択して開始します。"
                                           Foreground="#5F6B7A" Margin="0,4,0,8" TextWrapping="Wrap" />
                                <WrapPanel>
                                    <Button Content="収集を開始" Click="StartCapture_Click" />
                                    <Button Content="収集を終了" Click="StopCapture_Click" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource Card}" Margin="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="2. DDR GPで曲を移動" FontSize="16" FontWeight="SemiBold" />
                                <TextBlock Text="ジャケットが安定すると、上の保存ボタンが押せるようになります。"
                                           Foreground="#5F6B7A" Margin="0,4,0,0" TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0">
                                    <Run Text="INFORMATION: " />
                                    <Run Text="{Binding Observation.InformationPanelDisplay, Mode=OneWay}" />
                                    <Run Text="   曲名行: " />
                                    <Run Text="{Binding Observation.InformationTitleLineStability, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Text="{Binding Observation.InformationTitleLineHash}"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Expander Header="詳細・復旧操作" Margin="0,14,0,0">
                            <StackPanel Margin="8">
                                <TextBlock Text="{Binding WindowCapture.Lifecycle.Message}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding WindowCapture.CaptureState}" FontFamily="Consolas" FontSize="11" />
                                <TextBlock Text="{Binding WindowCapture.CaptureCounts}" FontFamily="Consolas" FontSize="11" />
                                <TextBlock Text="{Binding Observation.DetectorProgress}" FontFamily="Consolas" FontSize="11" />
                                <TextBlock Text="{Binding Observation.StableCandidate}" FontFamily="Consolas" FontSize="11" />
                                <TextBlock Text="{Binding Observation.InformationDiagnostic}"
                                           FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,2">
                                    <Run Text="session: " /><Run Text="{Binding Observation.SessionId, Mode=OneWay}" />
                                </TextBlock>
                                <TextBox Padding="6" ToolTip="compatible checkpointのsession ID"
                                         Text="{Binding Observation.ResumeSessionId, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel>
                                    <Button Content="session再開" IsEnabled="{Binding Observation.CanResume}"
                                            Click="ResumeCapture_Click" />
                                    <Button Content="catalog retry" IsEnabled="{Binding Observation.CanRetryCatalog}"
                                            Click="RetryCatalog_Click" />
                                </WrapPanel>
                                <TextBlock Text="{Binding Observation.CollectionResult}"
                                           Foreground="#5F6B7A" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding Observation.StatusMessage}" Foreground="#5F6B7A"
                                           TextWrapping="Wrap" Margin="0,6,0,0" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="収集状況">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <TextBlock Text="状態" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox Width="150" ItemsSource="{Binding CoverageStatusOptions}"
                                      SelectedItem="{Binding SelectedCoverageStatus}" Margin="0,0,12,0" />
                            <TextBlock Text="理由" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <ComboBox Width="240" ItemsSource="{Binding ReasonOptions}"
                                      SelectedItem="{Binding SelectedReason}" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="{Binding CoverageSummary}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OrphanSummary}" Foreground="#5F6B7A" />
                        </StackPanel>
                    </DockPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Songs}" IsReadOnly="True" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="状態" Binding="{Binding CoverageStatus}" Width="120" />
                            <DataGridTextColumn Header="曲名" Binding="{Binding Title}" Width="2*" />
                            <DataGridTextColumn Header="アーティスト" Binding="{Binding Artist}" Width="*" />
                            <DataGridTextColumn Header="登録数" Binding="{Binding ReferenceCount}" Width="70" />
                            <DataGridTextColumn Header="理由" Binding="{Binding Reason}" Width="2*" />
                            <DataGridTextColumn Header="song_id" Binding="{Binding SongId}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="レビュー">
                <TabControl Margin="0">
                    <TabItem Header="未レビュー">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1"
                                            CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                                        <TextBlock Foreground="#1E40AF" FontWeight="Bold">
                                            <Run Text="未レビュー  " />
                                            <Run Text="{Binding ManualReviewUnreviewedCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#ECFDF5" BorderBrush="#A7F3D0" BorderThickness="1"
                                            CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                                        <TextBlock Foreground="#065F46" FontWeight="Bold">
                                            <Run Text="確定  " />
                                            <Run Text="{Binding ManualReviewConfirmedCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                                            CornerRadius="6" Padding="12,8" Margin="0,0,8,0">
                                        <TextBlock Foreground="#991B1B" FontWeight="Bold">
                                            <Run Text="却下  " />
                                            <Run Text="{Binding ManualReviewRejectedCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,8">
                                        <TextBlock Foreground="#92400E" FontWeight="Bold">
                                            <Run Text="保留  " />
                                            <Run Text="{Binding ManualReviewHoldCount, Mode=OneWay}" />
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <Button Content="一括反映"
                                            Style="{StaticResource PrimaryButton}"
                                            Click="SaveDraft_Click" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,8,0">
                                    <TextBlock Text="選択行のタイトルROI (拡大表示)" FontWeight="SemiBold"
                                               Foreground="#6B7280" Margin="0,0,0,8" />
                                    <Border Height="82" Background="#111827" BorderBrush="#374151"
                                            BorderThickness="1" CornerRadius="6" Padding="4">
                                        <Image Source="{Binding SelectedManualReviewRow.TitleRoiImagePath, Converter={StaticResource ManualReviewRoiImageConverter}, ConverterParameter=title}"
                                               Stretch="Uniform" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="選択行のアーティストROI (拡大表示)" FontWeight="SemiBold"
                                               Foreground="#6B7280" Margin="0,0,0,8" />
                                    <Border Height="82" Background="#111827" BorderBrush="#374151"
                                            BorderThickness="1" CornerRadius="6" Padding="4">
                                        <Image Source="{Binding SelectedManualReviewRow.ArtistRoiImagePath, Converter={StaticResource ManualReviewRoiImageConverter}, ConverterParameter=artist}"
                                               Stretch="Uniform" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="2" ItemsSource="{Binding ManualReviewRows}"
                                      SelectedItem="{Binding SelectedManualReviewRow, Mode=TwoWay}"
                                      IsReadOnly="False" AutoGenerateColumns="False" SelectionMode="Single"
                                      RowHeight="96" CanUserAddRows="False" HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal" Background="White">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="タイトルROI (切り出し画像)" Width="150" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Source="{Binding TitleRoiImagePath, Converter={StaticResource ManualReviewRoiImageConverter}, ConverterParameter=title}"
                                                       Width="120" Height="48" Stretch="Uniform" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="アーティストROI (切り出し画像)" Width="165" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Image Source="{Binding ArtistRoiImagePath, Converter={StaticResource ManualReviewRoiImageConverter}, ConverterParameter=artist}"
                                                       Width="130" Height="48" Stretch="Uniform" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="状態" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding StatusOptions}"
                                                          DisplayMemberPath="Display"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Margin="2" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="確定曲" Width="290">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBox Text="{Binding SongSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             ToolTip="title / alias / artist / song ID" />
                                                    <ComboBox ItemsSource="{Binding SongChoices}"
                                                              SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
                                                              IsEditable="False">
                                                        <ComboBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}" />
                                                                    <TextBlock Text="{Binding Artist}" Foreground="#6B7280" FontSize="11" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ComboBox.ItemTemplate>
                                                    </ComboBox>
                                                    <TextBlock Text="{Binding TruthSongDisplay, Mode=OneWay}"
                                                               Foreground="#6B7280" FontSize="11" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="メモ" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         MinHeight="58" AcceptsReturn="True" TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="保存状態 / エラー" Width="165" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DraftStateDisplay}" TextWrapping="Wrap" Margin="4">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#EF4444" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSaved, Mode=OneWay}" Value="True">
                                                                    <Setter Property="Foreground" Value="#10B981" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="observation_id" Width="100" IsReadOnly="True">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding ObservationIdShort, Mode=OneWay}" ToolTip="{Binding ObservationId}"
                                                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                                                         FontFamily="Consolas" Margin="4" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>
                    <TabItem Header="レビュー済み (後続Issue)" IsEnabled="False" />
                </TabControl>
            </TabItem>
            <TabItem Header="管理・設定">
                <StackPanel Margin="18" MaxWidth="900" HorizontalAlignment="Left">
                    <TextBlock Text="データベース" FontSize="20" FontWeight="SemiBold" />
                    <Border Style="{StaticResource Card}" Margin="0,10,0,14" Width="880">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="master" FontWeight="Bold" />
                                <TextBlock Text="{Binding MasterVersion}" />
                                <TextBlock Text="{Binding MasterSourceHash}" FontFamily="Consolas" FontSize="11" />
                                <TextBlock Text="{Binding MasterCounts}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="catalog" FontWeight="Bold" />
                                <TextBlock>
                                    <Run Text="{Binding CatalogIdentity, Mode=OneWay}" />
                                    <Run Text=" / " /><Run Text="{Binding CatalogSchema, Mode=OneWay}" />
                                </TextBlock>
                                <TextBlock Text="{Binding OrphanSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <WrapPanel>
                        <Button Content="曲情報を更新" Click="UpdateMaster_Click" />
                        <Button Content="title/artist評価" Click="EvaluateTitleArtist_Click" />
                        <Button Content="処理を取消" Click="CancelOperation_Click" />
                    </WrapPanel>
                    <Border Style="{StaticResource Card}" Margin="0,18,0,0" Width="880">
                        <StackPanel>
                            <TextBlock Text="直近の処理" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding StatusTitle}" Margin="0,6,0,0" />
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#5F6B7A" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
