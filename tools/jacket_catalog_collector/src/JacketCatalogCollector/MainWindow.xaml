<Window x:Class="JacketCatalogCollector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DDR GP Jacket Catalog Collector (Developer)" Height="820" Width="1320"
        MinHeight="640" MinWidth="1000">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="masterを更新" Margin="0,0,8,0" Padding="14,8" Click="UpdateMaster_Click" />
                <Button Content="master/catalogを選択" Margin="0,0,8,0" Padding="14,8" Click="SelectDatabases_Click" />
                <Button Content="処理を取消" Padding="14,8" Click="CancelOperation_Click" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Jacket Catalog Collector" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Developer-only / read-only coverage &amp; review projection" Foreground="DimGray" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Margin="0,14,0,0" Padding="12" Background="#EEF3F8" CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="master" FontWeight="Bold" />
                    <TextBlock Text="{Binding MasterVersion}" />
                    <TextBlock Text="{Binding MasterSourceHash}" FontFamily="Consolas" FontSize="11" />
                    <TextBlock Text="{Binding MasterCounts}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="catalog" FontWeight="Bold" />
                    <TextBlock><Run Text="{Binding CatalogIdentity}" /><Run Text=" / " /><Run Text="{Binding CatalogSchema}" /></TextBlock>
                    <TextBlock Text="{Binding CoverageSummary}" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding OrphanSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,12,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <TextBlock Text="status" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Width="150" ItemsSource="{Binding CoverageStatusOptions}"
                          SelectedItem="{Binding SelectedCoverageStatus}" Margin="0,0,12,0" />
                <TextBlock Text="reason" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Width="240" ItemsSource="{Binding ReasonOptions}"
                          SelectedItem="{Binding SelectedReason}" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="{Binding StatusTitle}" FontWeight="Bold" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="DimGray" TextWrapping="Wrap" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="3">
            <TabItem Header="Coverage songs">
                <DataGrid ItemsSource="{Binding Songs}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="status" Binding="{Binding CoverageStatus}" Width="120" />
                        <DataGridTextColumn Header="song" Binding="{Binding Title}" Width="2*" />
                        <DataGridTextColumn Header="artist" Binding="{Binding Artist}" Width="*" />
                        <DataGridTextColumn Header="refs" Binding="{Binding ReferenceCount}" Width="60" />
                        <DataGridTextColumn Header="reason" Binding="{Binding Reason}" Width="2*" />
                        <DataGridTextColumn Header="song_id" Binding="{Binding SongId}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Review queue">
                <DataGrid ItemsSource="{Binding ReviewReferences}" IsReadOnly="True" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="status" Binding="{Binding ReviewStatus}" Width="110" />
                        <DataGridTextColumn Header="observed title" Binding="{Binding ObservedTitle}" Width="*" />
                        <DataGridTextColumn Header="observed artist" Binding="{Binding ObservedArtist}" Width="*" />
                        <DataGridTextColumn Header="reason" Binding="{Binding Reason}" Width="*" />
                        <DataGridCheckBoxColumn Header="drift" Binding="{Binding MasterDrift}" Width="60" />
                        <DataGridTextColumn Header="candidates" Binding="{Binding CandidateDisplay}" Width="2*" />
                        <DataGridTextColumn Header="reference_id" Binding="{Binding ReferenceId}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
